# Firebase Configuration
FIREBASE_CREDENTIALS_PATH=./firebase_credentials.json

# Ollama Configuration (Local Llama 3.2)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Google Search Configuration (Optional)
# Choose one approach:
# 1. Using SerpApi (recommended for reliability)
SERPAPI_KEY=your_serpapi_key_here

# 2. Using Google Custom Search API
GOOGLE_API_KEY=your_google_api_key_here

# Cache Configuration
CACHE_DIR=./cache
CACHE_TTL_SECONDS=86400

# API Configuration
API_V1_PREFIX=/api/v1

# Server Configuration (optional, defaults to localhost:8000)
# HOST=0.0.0.0
# PORT=8000
